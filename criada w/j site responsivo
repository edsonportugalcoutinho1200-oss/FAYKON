        function filterProducts(type) {
            const buttons = document.querySelectorAll('button[onclick^="filterProducts"]');
            buttons.forEach(btn => {
                btn.classList.remove('bg-lime-400', 'text-black');
                btn.classList.add('bg-gray-200', 'dark:bg-dark-700');
            });
            event.target.classList.remove('bg-gray-200', 'dark:bg-dark-700');
            event.target.classList.add('bg-lime-400', 'text-black');

            if (type === 'all') {
                renderProducts(products);
            } else if (type === 'promo') {
                renderProducts(products.filter(p => p.promo));
            }
        }

